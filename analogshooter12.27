
package org.firstinspires.ftc.teamcode;

import com.qualcomm.robotcore.eventloop.opmode.LinearOpMode;
import com.qualcomm.robotcore.eventloop.opmode.TeleOp;
import com.qualcomm.robotcore.hardware.DcMotor;
import com.qualcomm.robotcore.hardware.Servo;
import com.qualcomm.robotcore.util.ElapsedTime;
import com.qualcomm.robotcore.util.Range;

@TeleOp(name = "Analog Shooter (Fast)", group = "TeleOp")
public class analogshooter extends LinearOpMode {

    // Shooter hardware
    private DcMotor launchMotor;
    private Servo finger;

    // Finger timing
    private boolean fingerActive = false;
    private ElapsedTime fingerTimer = new ElapsedTime();
    private final double FINGER_FLICK_TIME = 0.12;

    // Servo positions (goBILDA-style 300° servo)
    private final double FINGER_REST = degToPos(0);
    private final double FINGER_FIRE = degToPos(90); // adjust as needed

    @Override
    public void runOpMode() {

        launchMotor = hardwareMap.get(DcMotor.class, "launch_motor");
        finger = hardwareMap.get(Servo.class, "Trigger");

        finger.setPosition(FINGER_REST);
        launchMotor.setPower(0);

        telemetry.addLine("Analog Shooter READY");
        telemetry.addLine("RT = spin shooter | RB = shoot");
        telemetry.update();

        waitForStart();

        while (opModeIsActive()) {

            // ===== CONTINUOUS SHOOTER =====
            if (gamepad2.right_trigger > 0.1) {
                launchMotor.setPower(1.0);
                telemetry.addData("Shooter", "SPINNING");
            } else {
                launchMotor.setPower(0.0);
                telemetry.addData("Shooter", "STOPPED");
            }

            // ===== FAST FINGER FEED =====
            if (gamepad2.right_bumper && !fingerActive) {
                fingerActive = true;
                fingerTimer.reset();
                finger.setPosition(FINGER_FIRE);
            }

            if (fingerActive && fingerTimer.seconds() > FINGER_FLICK_TIME) {
                finger.setPosition(FINGER_REST);
                fingerActive = false;
            }

            telemetry.addData("Finger", fingerActive ? "FIRING" : "READY");
            telemetry.update();
        }
    }

    // Convert degrees (0–300) to servo position (0–1)
    private static double degToPos(double degrees) {
        return Range.clip(degrees / 300.0, 0.0, 1.0);
    }
}
